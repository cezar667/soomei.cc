      "name": "00 - Preparar rodada",
      "item": [
        {
          "name": "Gerar novo run_id",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('run_id', Date.now().toString());",
                  "console.log('Novo run_id:', pm.collectionVariables.get('run_id'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('run_id gerado', function () {",
                  "  pm.expect(pm.collectionVariables.get('run_id')).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        }
      ]
    },
