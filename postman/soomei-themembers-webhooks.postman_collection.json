              "raw": "{\n  \"id\": \"wh_tm_access_granted_{{run_id}}\",\n  \"object\": \"access\",\n  \"event\": \"access.granted\",\n  \"created_at\": \"2026-07-12T12:00:00.000Z\",\n  \"token\": \"{{themembers_token}}\",\n  \"data\": {\n    \"id\": \"access_tm_{{run_id}}\",\n    \"order\": { \"id\": \"order_tm_{{run_id}}\" },\n    \"product\": { \"id\": \"soomei-card-black\", \"name\": \"Soomei Card Black\" },\n    \"customer\": {\n      \"id\": \"customer_tm_{{run_id}}\",\n      \"name\": \"Cliente TheMembers {{run_id}}\",\n      \"email\": \"cliente.themembers.{{run_id}}@example.com\",\n      \"phone\": \"5534999999999\",\n      \"document\": \"00000000000\"\n    }\n  }\n}"
