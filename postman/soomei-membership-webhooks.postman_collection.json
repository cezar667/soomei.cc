{
  "info": {
    "_postman_id": "a8e06de4-1e25-4c26-861e-soomei-webhooks",
    "name": "Soomei - Membership Webhooks",
    "description": "Collection para validar o módulo de webhooks da plataforma externa de associados. O script de pré-request assina automaticamente o corpo bruto com HMAC-SHA256 usando `webhook_secret`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('run_id')) {",
          "  pm.collectionVariables.set('run_id', Date.now().toString());",
          "}",
          "",
          "const rawTemplate = pm.request.body && pm.request.body.raw ? pm.request.body.raw : '';",
          "if (rawTemplate) {",
          "  const rawBody = pm.variables.replaceIn(rawTemplate);",
          "  const timestamp = Math.floor(Date.now() / 1000).toString();",
          "  const secret = pm.collectionVariables.get('webhook_secret') || pm.environment.get('webhook_secret') || '';",
          "  const signature = 'sha256=' + CryptoJS.HmacSHA256(timestamp + '.' + rawBody, secret).toString(CryptoJS.enc.Hex);",
          "  let eventId = 'evt_unknown';",
          "  try { eventId = JSON.parse(rawBody).event_id || eventId; } catch (e) {}",
          "  pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "  pm.request.headers.upsert({ key: 'X-Webhook-Timestamp', value: timestamp });",
          "  pm.request.headers.upsert({ key: 'X-Webhook-Signature', value: signature });",
          "  pm.request.headers.upsert({ key: 'X-Webhook-Event-Id', value: eventId });",
          "  pm.request.headers.upsert({ key: 'X-Correlation-Id', value: 'postman-' + pm.collectionVariables.get('run_id') });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "webhook_secret",
      "value": "segredo-teste-123",
      "type": "secret"
    },
    {
      "key": "run_id",
      "value": "001"
    }
  ],
