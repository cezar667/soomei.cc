              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const rawBody = pm.variables.replaceIn(pm.request.body.raw || '');",
                  "const oldTimestamp = (Math.floor(Date.now() / 1000) - 9999).toString();",
                  "const secret = pm.collectionVariables.get('webhook_secret') || pm.environment.get('webhook_secret') || '';",
                  "const signature = 'sha256=' + CryptoJS.HmacSHA256(oldTimestamp + '.' + rawBody, secret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Timestamp', value: oldTimestamp });",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Signature', value: signature });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401 Unauthorized', function () { pm.response.to.have.status(401); });"
