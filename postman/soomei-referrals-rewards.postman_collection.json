    {
      "name": "00 - Preparar rodada",
      "item": [
        {
          "name": "Gerar dados únicos da rodada",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = Date.now().toString();",
                  "const suffix = runId.slice(-8);",
                  "pm.collectionVariables.set('run_id', runId);",
                  "pm.collectionVariables.set('password', 'SenhaPostman123');",
                  "pm.collectionVariables.set('referrer_uid', 'pmra' + suffix);",
                  "pm.collectionVariables.set('referred_uid', 'pmrb' + suffix);",
                  "pm.collectionVariables.set('referrer_pin', '111111');",
                  "pm.collectionVariables.set('referred_pin', '222222');",
                  "pm.collectionVariables.set('referrer_email', 'indicador.' + suffix + '@example.com');",
                  "pm.collectionVariables.set('referred_email', 'indicado.' + suffix + '@example.com');",
                  "pm.collectionVariables.set('referrer_slug', 'indicador-' + suffix);",
                  "pm.collectionVariables.set('referred_slug', 'indicado-' + suffix);",
                  "pm.collectionVariables.unset('csrf_token');",
                  "pm.collectionVariables.unset('referral_code');",
                  "pm.collectionVariables.unset('referrer_verify_path');",
                  "pm.collectionVariables.unset('referred_verify_path');",
                  "console.log('Dados gerados para a rodada de indicação:', {",
                  "  referrer_uid: pm.collectionVariables.get('referrer_uid'),",
                  "  referrer_pin: pm.collectionVariables.get('referrer_pin'),",
                  "  referred_uid: pm.collectionVariables.get('referred_uid'),",
                  "  referred_pin: pm.collectionVariables.get('referred_pin')",
                  "});",
                  "console.log('Crie os cartões localmente com:');",
                  "console.log('py scripts/add_card.py --uid ' + pm.collectionVariables.get('referrer_uid') + ' --pin ' + pm.collectionVariables.get('referrer_pin'));",
                  "console.log('py scripts/add_card.py --uid ' + pm.collectionVariables.get('referred_uid') + ' --pin ' + pm.collectionVariables.get('referred_pin'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('dados da rodada gerados', function () {",
                  "  pm.expect(pm.collectionVariables.get('referrer_uid')).to.match(/^pmra/);",
                  "  pm.expect(pm.collectionVariables.get('referred_uid')).to.match(/^pmrb/);",
                  "});",
                  "pm.test('rode os scripts/add_card antes do onboarding', function () {",
                  "  console.log('Indicador:', pm.collectionVariables.get('referrer_uid'), pm.collectionVariables.get('referrer_pin'));",
                  "  console.log('Indicado:', pm.collectionVariables.get('referred_uid'), pm.collectionVariables.get('referred_pin'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Gera UIDs, PINs, e-mails e slugs únicos. Depois rode no terminal, antes do onboarding:\n\n`py scripts/add_card.py --uid {{referrer_uid}} --pin {{referrer_pin}}`\n`py scripts/add_card.py --uid {{referred_uid}} --pin {{referred_pin}}`\n\nSe preferir criar cartões via webhook, use a pasta opcional abaixo e consulte o banco para descobrir UID/PIN gerados."
          }
        }
